{
	"manifest_version": 3,
	"name": "Ado Light Show",
	"version": "1.1.0",
	"icons": {
		"16": "icon16.png",
		"32": "icon32.png",
		"48": "icon48.png",
		"128": "icon128.png"
	},
	"description": "This extension uses your Ado penlight and custom made scripts to enhance the experience of watching Ado's music videos on YouTube.",
	"action": {
		"default_popup": "src/page/popup/index.html"
	},
	"background": {
		"service_worker": "src/background/index.ts",
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": ["https://www.youtube.com/*"],
			"js": ["src/content/index.ts"]
		}
	],
	"permissions": ["tabs"],
	"web_accessible_resources": [
		{
			"matches": ["https://www.youtube.com/*"],
			"resources": ["command-encoder.wasm"]
		},
		{
			"matches": ["<all_urls>"],
			"resources": ["src/page/penlight-manager/index.html"]
		}
	],
	"content_security_policy": {
		"extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
	}
}
